// Type system test page вЂ” open this in VSCode to verify type checking.
// Lines marked вњ“ should have NO errors. Lines marked вњ— SHOULD error.

// в”Ђв”Ђ Import navigation в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// Cmd+click on the path strings to jump to the file

import { Todo, Filter } from "../types"    // вњ“ cmd+click "../types" в†’ opens types.fl
import "../todo"                            // вњ“ cmd+click "../todo" в†’ opens todo.fl

// в”Ђв”Ђ Member access в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// Hover over .text, .done вЂ” should show string, boolean

const todo = Todo(id: "1", text: "Buy milk", done: false)
const _name = todo.text       // вњ“ hover: string
const _done = todo.done       // вњ“ hover: boolean
// const _bad = todo.nonexistent // вњ— uncomment в†’ "type `Todo` has no field `nonexistent`"

// в”Ђв”Ђ Constructor validation в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// Wrong field types should error

const _good = Todo(id: "1", text: "hi", done: false)  // вњ“
// const _bad1 = Todo(id: 42, text: "hi", done: false)   // вњ— uncomment в†’ field `id`: expected `string`, found `number`
// const _bad2 = Todo(id: "1", text: "hi", done: "yes")  // вњ— uncomment в†’ field `done`: expected `boolean`, found `string`

// в”Ђв”Ђ Match arm consistency в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// All arms must return the same type

fn describeFilter(f: Filter) -> string {
    match f {
        All -> "all",
        Active -> "active",
        Completed -> "completed",
    }
}

// Uncomment to see error: match arms have incompatible types
// fn badMatch(f: Filter) -> string {
//     match f {
//         All -> "all",
//         Active -> 42,
//         Completed -> "completed",
//     }
// }

// в”Ђв”Ђ If/else branch consistency в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

fn abs(x: number) -> number {
    if x > 0 { x } else { 0 - x }  // вњ“ both branches are number
}

// Uncomment to see error: incompatible types in if/else
// fn badIfElse(x: number) -> number {
//     if x > 0 { x } else { "negative" }
// }

// в”Ђв”Ђ Pipe type checking в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

fn double(x: number) -> number { x * 2 }
const _piped = 5 |> double          // вњ“
// const _badPipe = "hi" |> double  // вњ— uncomment в†’ expected `number`, found `string`

// в”Ђв”Ђ Shadowing в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

const myVal = 5
// const myVal = 10  // вњ— uncomment в†’ already defined and cannot be shadowed

// в”Ђв”Ђ Return type mismatch в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

fn greet() -> string { "hello" }  // вњ“
// fn badReturn() -> string { 42 }  // вњ— uncomment в†’ return type mismatch
